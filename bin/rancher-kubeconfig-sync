#!/usr/bin/env bash
set -euo pipefail

dest_dir="${1:-$HOME/.kube/rancher}"
mkdir -p "$dest_dir"

if ! command -v rancher >/dev/null 2>&1; then
  printf 'rancher CLI not found\n' >&2
  exit 1
fi

cluster_ids="$(rancher clusters ls -q)"

if [[ -z "$cluster_ids" ]]; then
  printf 'no clusters returned by rancher clusters ls -q\n' >&2
  exit 1
fi

synced=0
failed=0

while IFS= read -r id; do
  [[ -z "$id" ]] && continue

  kc="$(rancher clusters kf "$id" 2>/dev/null)" || {
    printf 'WARN: failed to get kubeconfig for %s, skipping\n' "$id" >&2
    (( failed++ ))
    continue
  }

  # extract context name from the kubeconfig to use as filename
  name="$(printf '%s' "$kc" | grep 'current-context:' | sed 's/current-context:[[:space:]]*//' | tr -d '"')"

  if [[ -z "$name" ]]; then
    printf 'WARN: no context name found in kubeconfig for %s, using ID as filename\n' "$id" >&2
    name="$id"
  fi

  printf '%s' "$kc" > "$dest_dir/${name}.yaml"
  chmod 600 "$dest_dir/${name}.yaml"
  printf 'synced %s -> %s/%s.yaml\n' "$id" "$dest_dir" "$name"
  (( synced++ ))
done <<< "$cluster_ids"

printf '\nsynced %d cluster(s), %d failed\n' "$synced" "$failed"
