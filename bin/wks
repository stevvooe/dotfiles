#!/usr/bin/env bash

set -euo pipefail

emsg() {
  printf '%s\n' "$*" >&2
}

usage() {
  cat <<'EOF'
Usage:
  wks                  # ensure + attach the tmux session for the current workspace
  wks ls [--status]
  wks new <name> [--base <ref>] [--no-attach]
  wks new --fix <name> [--base <ref>] [--no-attach]
  wks new --feat <name> [--base <ref>] [--no-attach]
  wks new <name> --branch <branch> [--base <ref>] [--no-attach]
  wks names
  wks rows
  wks diff [name]
  wks sw [name]
  wks switch [name]
  wks rename <old> <new>
  wks rm [name] [--force] [--prune-branch]
  wks clone <owner/repo>
  wks adopt [--all]
  wks path [name]

Commands:
  (no args)            Ensure + attach the tmux session for the current workspace.
                       Outside a workspace, fall back to the session picker.
  ls [--status]        List worktrees (--status adds dirty/clean check)
  new                  Create .workspaces/<name> from --base (default: origin/HEAD),
                       then attach its session (--no-attach to skip)
  names                Print workspace names (for scripting/completion)
  rows                 Print tab-delimited workspace rows (name, branch, state, path)
  diff                 Show git status and diff for a workspace
  sw, switch           Print selected workspace path (fzf when no name)
  rename               Rename workspace directory, wks/* branch, and tmux session
  rm                   Lifecycle-aware delete. Checkout: kill its session only.
                       Worktree: kill session (if any) and remove the worktree;
                       refuses dirty unless --force. --prune-branch deletes the
                       local branch after removal. Defaults to current workspace.
  clone                Clone a GitHub repo (owner/repo) via cleanclone into
                       $CODEHOME and open a session. Idempotent if it exists.
  adopt                Backfill @wks_root on the current session (--all: every session)
  path                 Print current workspace root, or named workspace path

Notes:
  - Workspaces live under <main checkout>/.workspaces
  - New workspaces default to branch wks/<name>
  - --fix/--feat create fix/<user>/<name> or feat/<user>/<name>
  - --branch uses an explicit branch name
  - Session names are short (checkout basename, worktree name); the canonical
    workspace identity is the path. Sessions store @wks_root for identity.
  - Use a shell wrapper to cd after switch output
EOF
}

require_git_repo() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    emsg "error: not inside a git repository"
    exit 1
  fi
}

init_repo_paths() {
  git_common_dir=$(git rev-parse --path-format=absolute --git-common-dir)
  main_root=$(cd "$git_common_dir/.." && pwd -P)
  workspaces_dir="$main_root/.workspaces"
  current_root=$(git rev-parse --show-toplevel)
}

ensure_local_exclude() {
  local exclude_file

  exclude_file=$(git rev-parse --path-format=absolute --git-path info/exclude)
  if [ ! -f "$exclude_file" ]; then
    touch "$exclude_file"
  fi

  if ! grep -qxF '/.workspaces/' "$exclude_file"; then
    printf '\n/.workspaces/\n' >>"$exclude_file"
  fi
}

branch_for_path() {
  local path=$1
  local branch

  if branch=$(git -C "$path" symbolic-ref --short -q HEAD 2>/dev/null); then
    printf '%s\n' "$branch"
    return
  fi

  branch=$(git -C "$path" rev-parse --short HEAD)
  printf 'detached@%s\n' "$branch"
}

state_for_path() {
  local path=$1

  if [ -n "$(git -C "$path" status --porcelain --ignore-submodules=dirty)" ]; then
    printf 'dirty\n'
  else
    printf 'clean\n'
  fi
}

workspace_rows() {
  local with_state=0
  if [ "${1:-}" = "--with-state" ]; then
    with_state=1
  fi

  local -a ws_paths ws_names
  ws_paths=("$main_root")
  ws_names=("main")

  if [ -d "$workspaces_dir" ]; then
    for path in "$workspaces_dir"/*; do
      [ -d "$path" ] || continue
      git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1 || continue
      ws_paths+=("$path")
      ws_names+=("$(basename "$path")")
    done
  fi

  local tmpdir=
  if [ "$with_state" -eq 1 ]; then
    tmpdir=$(mktemp -d)
    for i in "${!ws_paths[@]}"; do
      ( state_for_path "${ws_paths[$i]}" >"$tmpdir/$i" ) &
    done
    wait
  fi

  local i branch state
  for i in "${!ws_paths[@]}"; do
    branch=$(branch_for_path "${ws_paths[$i]}")
    if [ "$with_state" -eq 1 ]; then
      state=$(<"$tmpdir/$i")
    else
      state="-"
    fi
    printf '%s\t%s\t%s\t%s\n' "${ws_names[$i]}" "$branch" "$state" "${ws_paths[$i]}"
  done

  if [ -n "$tmpdir" ]; then
    rm -rf "$tmpdir"
  fi
}

workspace_names() {
  local name branch state path

  workspace_rows | while IFS=$'\t' read -r name branch state path; do
    printf '%s\n' "$name"
  done
}

resolve_workspace_path() {
  local name=$1
  local path

  if [ "$name" = "main" ]; then
    printf '%s\n' "$main_root"
    return 0
  fi

  path="$workspaces_dir/$name"
  if [ -d "$path" ] && git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf '%s\n' "$path"
    return 0
  fi

  emsg "error: workspace '$name' not found"
  return 1
}

validate_workspace_name() {
  local name=$1

  if [ -z "$name" ]; then
    emsg "error: workspace name cannot be empty"
    exit 1
  fi

  if [ "$name" = "main" ]; then
    emsg "error: 'main' is reserved"
    exit 1
  fi

  if [[ ! "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then
    emsg "error: workspace name must match [A-Za-z0-9._-]+"
    exit 1
  fi
}

branch_user() {
  local user=${WKS_BRANCH_USER:-${GITHUB_USER:-${USER:-}}}

  if [ -z "$user" ]; then
    emsg "error: could not determine branch user (set WKS_BRANCH_USER)"
    exit 1
  fi

  printf '%s\n' "$user"
}

validate_branch_name() {
  local branch=$1

  if ! git check-ref-format --branch "$branch" >/dev/null 2>&1; then
    emsg "error: invalid branch name '$branch'"
    exit 1
  fi
}

branch_for_kind() {
  local kind=$1
  local name=$2

  printf '%s/%s/%s\n' "$kind" "$(branch_user)" "$name"
}

resolve_workspace_branch() {
  local name=$1
  local explicit_branch=$2
  local branch_kind=$3

  if [ -n "$explicit_branch" ] && [ -n "$branch_kind" ]; then
    emsg "error: --branch cannot be combined with --$branch_kind"
    exit 1
  fi

  if [ -n "$explicit_branch" ]; then
    printf '%s\n' "$explicit_branch"
    return 0
  fi

  if [ -n "$branch_kind" ]; then
    branch_for_kind "$branch_kind" "$name"
    return 0
  fi

  printf 'wks/%s\n' "$name"
}

default_workspace_base() {
  local branch base

  if command -v gh >/dev/null 2>&1; then
    if branch=$(gh repo view --json defaultBranchRef --jq .defaultBranchRef.name 2>/dev/null) && [ -n "$branch" ]; then
      printf 'origin/%s\n' "$branch"
      return 0
    fi
  fi

  if base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null); then
    printf '%s\n' "$base"
    return 0
  fi

  if git show-ref --verify --quiet refs/remotes/origin/main; then
    printf 'origin/main\n'
    return 0
  fi

  if git show-ref --verify --quiet refs/remotes/origin/master; then
    printf 'origin/master\n'
    return 0
    fi

  emsg "error: could not determine default remote base (expected origin/HEAD, origin/main, or origin/master)"
  exit 1
}

set_branch_kind() {
  local current_kind=$1
  local next_kind=$2

  if [ -n "$current_kind" ] && [ "$current_kind" != "$next_kind" ]; then
    emsg "error: --$current_kind cannot be combined with --$next_kind"
    exit 1
  fi

  printf '%s\n' "$next_kind"
}

consume_option_value() {
  local flag=$1
  local label=$2
  shift 2

  if [ $# -eq 0 ] || [[ "$1" == -* ]]; then
    emsg "error: $flag requires a $label"
    exit 1
  fi

  printf '%s\n' "$1"
}

github_repo_slug() {
  local path=$1
  local remote_url slug

  remote_url=$(git -C "$path" config --get remote.origin.url 2>/dev/null || true)
  if [ -z "$remote_url" ]; then
    return 1
  fi

  case "$remote_url" in
    git@github.com:*)
      slug=${remote_url#git@github.com:}
      ;;
    https://github.com/*)
      slug=${remote_url#https://github.com/}
      ;;
    ssh://git@github.com/*)
      slug=${remote_url#ssh://git@github.com/}
      ;;
    *)
      return 1
      ;;
  esac

  slug=${slug%.git}
  if [[ ! "$slug" =~ ^[^/]+/[^/]+$ ]]; then
    return 1
  fi

  printf '%s\n' "$slug"
}

sanitize_session_name() {
  local name=$1

  name=${name//\//-}
  name=${name// /-}
  name=${name//:/-}
  name=${name//[^A-Za-z0-9._-]/-}
  while [[ "$name" == .* || "$name" == -* ]]; do
    name=${name#.}
    name=${name#-}
  done

  if [ -z "$name" ]; then
    name=dev
  fi

  printf '%s\n' "$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
}

workspace_kind_for() {
  local path=$1

  if [ "$path" = "$main_root" ]; then
    printf 'checkout\n'
  else
    printf 'worktree\n'
  fi
}

# Active pane cwd for a session. display-message -t '=name' does not resolve
# pane_current_path reliably, so use list-panes filtered to the active pane.
session_pane_path() {
  tmux list-panes -t "=$1" -F '#{?pane_active,#{pane_current_path},}' 2>/dev/null \
    | grep -v '^$' | head -1
}

# Resolve the @wks_root for a session, falling back to its active pane cwd.
session_root() {
  local session=$1
  local root

  root=$(tmux show-options -t "$session" -qv @wks_root 2>/dev/null || true)
  if [ -n "$root" ]; then
    printf '%s\n' "$root"
    return 0
  fi

  session_pane_path "$session"
}

# Compute the short tmux session name for a workspace path.
# worktree -> tree name; checkout -> basename, bumping to owner-repo on live collision.
session_name_for() {
  local path=$1
  local kind name base slug existing_root

  kind=$(workspace_kind_for "$path")

  if [ "$kind" = "worktree" ]; then
    sanitize_session_name "$(basename "$path")"
    return 0
  fi

  base=$(sanitize_session_name "$(basename "$path")")

  # Collision check: live session of this name pointing at a different root.
  if tmux has-session -t "=$base" 2>/dev/null; then
    existing_root=$(session_root "$base")
    if [ -n "$existing_root" ] && [ "$existing_root" != "$path" ]; then
      slug=$(github_repo_slug "$path" || true)
      if [ -n "$slug" ]; then
        sanitize_session_name "$slug"
        return 0
      fi
    fi
  fi

  printf '%s\n' "$base"
}

# Create the tmux session + window layout if missing, stamping @wks_root.
ensure_session() {
  local path=$1
  local session=$2

  if tmux has-session -t "=$session" 2>/dev/null; then
    return 0
  fi

  tmux new-session -d -s "$session" -n dev -c "$path"
  tmux set-option -t "$session" @wks_root "$path"
  tmux split-window -h -t "=$session":dev -c "$path"
  tmux new-window -t "=$session":2 -n zsh -c "$path"
  tmux select-window -t "=$session":dev
  tmux select-pane -t "=$session":dev.1
}

attach_or_switch() {
  local session=$1

  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "=$session"
  else
    tmux attach-session -t "=$session"
  fi
}

# Kill a session safely. If it is the session we are attached to, switch the
# client to the most-recently-used other session first so tmux does not exit.
safe_kill_session() {
  local victim=$1 next

  if [ -n "${TMUX:-}" ] && [ "$(tmux display-message -p '#S')" = "$victim" ]; then
    # Sort by session_activity desc, skip the victim, take the MRU survivor.
    next=$(tmux list-sessions -F '#{session_activity} #{session_name}' 2>/dev/null \
      | sort -rn | awk -v v="$victim" '{ $1=""; sub(/^ /,""); if ($0 != v) { print; exit } }')
    if [ -z "$next" ]; then
      emsg "refusing to kill $victim: it is the only session"
      return 1
    fi
    tmux switch-client -t "=$next"
  fi
  tmux kill-session -t "=$victim"
}

# Find an existing session whose @wks_root matches the given path. This is the
# canonical (path-based) identity, so a workspace is never double-sessioned
# just because an old session uses a drifted name (e.g. stevvooe-dotfiles).
session_for_root() {
  local want=$1 s root
  [ -z "$want" ] && return 1

  while IFS= read -r s; do
    [ -z "$s" ] && continue
    root=$(tmux show-options -t "$s" -qv @wks_root 2>/dev/null || true)
    if [ -n "$root" ] && [ "$root" = "$want" ]; then
      printf '%s\n' "$s"
      return 0
    fi
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

  return 1
}

# Naked `wks`: ensure + attach the session for the current workspace. Reuses an
# existing session for this path if one already exists (under any name).
cmd_attach_current() {
  local path session

  path=$current_root

  # Prefer an existing session already bound to this path.
  if session=$(session_for_root "$path"); then
    attach_or_switch "$session"
    return 0
  fi

  session=$(session_name_for "$path")
  ensure_session "$path" "$session"
  attach_or_switch "$session"
}

# Open a session for an arbitrary path: reuse an existing one bound to it,
# otherwise create + attach. Used by `clone` and any "open this dir" flow.
open_path() {
  local path=$1 session

  if session=$(session_for_root "$path"); then
    attach_or_switch "$session"
    return 0
  fi

  session=$(session_name_for "$path")
  ensure_session "$path" "$session"
  attach_or_switch "$session"
}

cleanclone_cmd() {
  local cmd
  cmd=$(command -v cleanclone 2>/dev/null || true)
  if [ -z "$cmd" ] && [ -x "$HOME/.dotfiles/bin/cleanclone" ]; then
    cmd=$HOME/.dotfiles/bin/cleanclone
  fi
  printf '%s\n' "$cmd"
}

# Clone a GitHub repo (short name, e.g. owner/repo) via cleanclone, then open a
# session in the checkout. Idempotent: an existing checkout is just opened.
cmd_clone() {
  local repo cc path

  repo=${1:-}
  if [ -z "$repo" ]; then
    emsg "error: usage: wks clone <owner/repo>"
    exit 1
  fi
  if [ $# -gt 1 ]; then
    emsg "error: unexpected extra argument '$2'"
    exit 1
  fi

  cc=$(cleanclone_cmd)
  if [ -z "$cc" ]; then
    emsg "error: cleanclone not found in PATH"
    exit 1
  fi

  # cleanclone prints the checkout path on stdout (only); progress is on stderr.
  path=$("$cc" "$repo") || exit $?
  if [ -z "$path" ] || [ ! -d "$path" ]; then
    emsg "error: clone did not produce a checkout path"
    exit 1
  fi

  # Enter the new checkout and establish repo context so naming classifies it
  # as a checkout (not a worktree) before opening the session.
  cd "$path"
  init_repo_paths
  open_path "$current_root"
}

cmd_adopt() {
  local all=0 session root top

  while [ $# -gt 0 ]; do
    case "$1" in
      --all) all=1; shift ;;
      *) emsg "error: unknown option '$1'"; exit 1 ;;
    esac
  done

  if [ -z "${TMUX:-}" ] && [ "$all" -eq 0 ]; then
    emsg "error: not in a tmux session (use --all to adopt every session)"
    exit 1
  fi

  adopt_one() {
    local s=$1 cwd resolved

    if [ -n "$(tmux show-options -t "$s" -qv @wks_root 2>/dev/null || true)" ]; then
      return 0
    fi

    cwd=$(session_pane_path "$s")
    [ -z "$cwd" ] && return 0

    if top=$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null); then
      resolved=$top
    else
      resolved=$cwd
    fi

    tmux set-option -t "$s" @wks_root "$resolved"
    emsg "adopted $s -> $resolved"
  }

  if [ "$all" -eq 1 ]; then
    while IFS= read -r session; do
      [ -n "$session" ] && adopt_one "$session"
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
  else
    session=$(tmux display-message -p '#S')
    adopt_one "$session"
  fi
}

cmd_ls() {
  local name branch state path marker with_state_flag=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --status) with_state_flag="--with-state"; shift ;;
      *) emsg "error: unknown option '$1'"; exit 1 ;;
    esac
  done

  workspace_rows $with_state_flag | while IFS=$'\t' read -r name branch state path; do
    marker=' '
    if [ "$path" = "$current_root" ]; then
      marker='*'
    fi
    if [ -n "$with_state_flag" ]; then
      printf '%s %-16s %-24s %-6s %s\n' "$marker" "$name" "$branch" "$state" "$path"
    else
      printf '%s %-16s %-24s %s\n' "$marker" "$name" "$branch" "$path"
    fi
  done
}

cmd_names() {
  workspace_names
}

cmd_rows() {
  local with_state_flag=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --status) with_state_flag="--with-state"; shift ;;
      *) emsg "error: unknown option '$1'"; exit 1 ;;
    esac
  done

  workspace_rows $with_state_flag
}

cmd_diff() {
  local name=${1:-} path status_output unstaged_diff staged_diff

  if [ $# -gt 1 ]; then
    emsg "error: unexpected extra argument '$2'"
    exit 1
  fi

  if [ -n "$name" ]; then
    path=$(resolve_workspace_path "$name")
  else
    path=$current_root
  fi

  status_output=$(git -C "$path" status --short --branch)
  unstaged_diff=$(git -C "$path" diff)
  staged_diff=$(git -C "$path" diff --cached)

  printf 'Workspace: %s\n' "$path"
  printf '\n== Status ==\n'
  if [ -n "$status_output" ]; then
    printf '%s\n' "$status_output"
  else
    printf 'working tree clean\n'
  fi

  printf '\n== Unstaged Diff ==\n'
  if [ -n "$unstaged_diff" ]; then
    printf '%s\n' "$unstaged_diff"
  else
    printf 'No unstaged changes.\n'
  fi

  printf '\n== Staged Diff ==\n'
  if [ -n "$staged_diff" ]; then
    printf '%s\n' "$staged_diff"
  else
    printf 'No staged changes.\n'
  fi
}

cmd_switch() {
  local name=${1:-}

  if [ -n "$name" ]; then
    resolve_workspace_path "$name"
    return 0
  fi

  pick_workspace_path
}

pick_workspace_path() {
  local selected path

  if ! command -v fzf >/dev/null 2>&1; then
    emsg "error: fzf is required for interactive switching"
    exit 1
  fi

  selected=$(workspace_rows | fzf --prompt='workspace> ' --height=50% --layout=reverse --delimiter=$'\t' --with-nth=1,2)
  if [ -z "$selected" ]; then
    exit 1
  fi

  path=${selected##*$'\t'}
  printf '%s\n' "$path"
}

# Create the worktree only; prints the new path on stdout. No tmux side effects.
create_worktree() {
  local name=$1 base=$2 branch=$3 target

  validate_workspace_name "$name"
  validate_branch_name "$branch"
  target="$workspaces_dir/$name"

  if [ -e "$target" ]; then
    emsg "error: workspace path already exists: $target"
    exit 1
  fi

  if git show-ref --verify --quiet "refs/heads/$branch"; then
    emsg "error: branch already exists: $branch"
    exit 1
  fi

  ensure_local_exclude
  mkdir -p "$workspaces_dir"
  git worktree add -b "$branch" "$target" "$base" >/dev/null
  printf '%s\n' "$target"
}

cmd_new() {
  local name base branch branch_kind explicit_branch no_attach target session

  no_attach=0
  name=
  base=
  branch_kind=
  explicit_branch=

  while [ $# -gt 0 ]; do
    case "$1" in
      --no-attach)
        no_attach=1
        shift
        ;;
      --base)
        shift
        if [ $# -eq 0 ]; then
          emsg "error: --base requires a ref"
          exit 1
        fi
        base=$1
        shift
        ;;
      --branch)
        shift
        explicit_branch=$(consume_option_value --branch "branch name" "$@")
        shift
        ;;
      --branch=*)
        explicit_branch=${1#--branch=}
        if [ -z "$explicit_branch" ]; then
          emsg "error: --branch requires a branch name"
          exit 1
        fi
        shift
        ;;
      --fix)
        branch_kind=$(set_branch_kind "$branch_kind" fix)
        shift
        ;;
      --fix=*)
        if [ -n "$name" ]; then
          emsg "error: workspace name already set to '$name'"
          exit 1
        fi
        branch_kind=$(set_branch_kind "$branch_kind" fix)
        name=${1#--fix=}
        shift
        ;;
      --feat)
        branch_kind=$(set_branch_kind "$branch_kind" feat)
        shift
        ;;
      --feat=*)
        if [ -n "$name" ]; then
          emsg "error: workspace name already set to '$name'"
          exit 1
        fi
        branch_kind=$(set_branch_kind "$branch_kind" feat)
        name=${1#--feat=}
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        if [ -z "$name" ]; then
          name=$1
          shift
          continue
        fi
        emsg "error: unknown option '$1'"
        exit 1
        ;;
    esac
  done

  if [ -z "$name" ]; then
    emsg "error: missing workspace name"
    exit 1
  fi

  if [ -z "$base" ]; then
    base=$(default_workspace_base)
  fi

  branch=$(resolve_workspace_branch "$name" "$explicit_branch" "$branch_kind")
  target=$(create_worktree "$name" "$base" "$branch")

  if [ "$no_attach" -eq 1 ]; then
    printf '%s\n' "$target"
    return 0
  fi

  session=$(session_name_for "$target")
  ensure_session "$target" "$session"
  attach_or_switch "$session"
}

cmd_rename() {
  local old_name new_name old_path new_path branch new_branch

  old_name=${1:-}
  new_name=${2:-}

  if [ -z "$old_name" ] || [ -z "$new_name" ]; then
    emsg "error: usage: wks rename <old> <new>"
    exit 1
  fi

  if [ $# -gt 2 ]; then
    emsg "error: unexpected extra argument '$3'"
    exit 1
  fi

  if [ "$old_name" = "main" ]; then
    emsg "error: cannot rename main workspace"
    exit 1
  fi

  validate_workspace_name "$new_name"
  old_path=$(resolve_workspace_path "$old_name")
  new_path="$workspaces_dir/$new_name"

  if [ -e "$new_path" ]; then
    emsg "error: workspace '$new_name' already exists"
    exit 1
  fi

  git worktree move "$old_path" "$new_path"

  branch=$(branch_for_path "$new_path")
  if [ "$branch" = "wks/$old_name" ]; then
    new_branch="wks/$new_name"
    validate_branch_name "$new_branch"
    git branch -m "$branch" "$new_branch"
    emsg "renamed branch $branch -> $new_branch"
  fi

  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "=$old_name" 2>/dev/null; then
    tmux rename-session -t "=$old_name" "$new_name"
    tmux set-option -t "$new_name" @wks_root "$new_path"
    emsg "renamed tmux session $old_name -> $new_name"
  fi

  emsg "renamed workspace $old_name -> $new_name"
}

cmd_rm() {
  local name force prune_branch path branch

  name=
  force=0
  prune_branch=0

  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--force)
        force=1
        shift
        ;;
      --prune-branch)
        prune_branch=1
        shift
        ;;
      -*)
        emsg "error: unknown option '$1'"
        exit 1
        ;;
      *)
        if [ -n "$name" ]; then
          emsg "error: unexpected extra argument '$1'"
          exit 1
        fi
        name=$1
        shift
        ;;
    esac
  done

  # Default to the current workspace when no name is given.
  if [ -z "$name" ]; then
    path=$current_root
  else
    path=$(resolve_workspace_path "$name")
  fi

  local kind session
  kind=$(workspace_kind_for "$path")
  session=$(session_name_for "$path")

  # Checkout: only ever kill its tmux session; never touch the worktree.
  if [ "$kind" = "checkout" ]; then
    if tmux has-session -t "=$session" 2>/dev/null; then
      safe_kill_session "$session"
      emsg "killed session $session (checkout left intact)"
    else
      emsg "nothing to delete: checkout has no session"
    fi
    return 0
  fi

  # Worktree: enforce the dirty guard unless --force.
  if [ $force -eq 0 ] && [ -n "$(git -C "$path" status --porcelain --ignore-submodules=dirty)" ]; then
    emsg "error: workspace has uncommitted changes (use --force to remove)"
    exit 1
  fi

  # Kill the worktree's session if it has one. safe_kill_session switches the
  # client to the most-recently-used other session first when we're attached
  # to the one being removed.
  if tmux has-session -t "=$session" 2>/dev/null; then
    safe_kill_session "$session"
  fi

  branch=$(branch_for_path "$path")

  if [ $force -eq 1 ]; then
    git worktree remove --force "$path"
  else
    git worktree remove "$path"
  fi

  git worktree prune >/dev/null 2>&1 || true

  if [ "$prune_branch" -eq 1 ] && [ -n "$branch" ] && [[ "$branch" != detached@* ]]; then
    if git show-ref --verify --quiet "refs/heads/$branch"; then
      git branch -D "$branch"
    fi
  fi
}

cmd_path() {
  local name=${1:-}

  if [ -z "$name" ]; then
    printf '%s\n' "$current_root"
    return
  fi

  resolve_workspace_path "$name"
}

workspace_switch_cmd() {
  local cmd

  cmd=$(command -v workspace-switch 2>/dev/null || true)
  if [ -z "$cmd" ] && [ -x "$HOME/.config/tmux/scripts/workspace-switch" ]; then
    cmd=$HOME/.config/tmux/scripts/workspace-switch
  fi

  printf '%s\n' "$cmd"
}

# Naked `wks`: attach the current workspace's session. Outside a git repo,
# fall back to the session picker.
cmd_default() {
  local picker

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    init_repo_paths
    cmd_attach_current
    return 0
  fi

  picker=$(workspace_switch_cmd)
  if [ -n "$picker" ]; then
    exec "$picker"
  fi

  emsg "error: not inside a workspace and no picker available"
  exit 1
}

main() {
  local cmd

  if [ $# -eq 0 ]; then
    cmd_default
    return 0
  fi

  cmd=$1
  shift

  # These run outside a git repo: adopt operates on tmux sessions; clone
  # creates the repo before any workspace context exists.
  if [ "$cmd" = "adopt" ]; then
    cmd_adopt "$@"
    return 0
  fi
  if [ "$cmd" = "clone" ]; then
    cmd_clone "$@"
    return 0
  fi

  require_git_repo
  init_repo_paths

  case "$cmd" in
    -h|--help|help)
      usage
      ;;
    ls)
      cmd_ls "$@"
      ;;
    new)
      cmd_new "$@"
      ;;
    names)
      cmd_names "$@"
      ;;
    rows)
      cmd_rows "$@"
      ;;
    diff)
      cmd_diff "$@"
      ;;
    sw|switch)
      cmd_switch "$@"
      ;;
    rename)
      cmd_rename "$@"
      ;;
    rm)
      cmd_rm "$@"
      ;;
    path)
      cmd_path "$@"
      ;;
    *)
      emsg "error: unknown command '$cmd'"
      usage
      exit 1
      ;;
  esac
}

main "$@"
