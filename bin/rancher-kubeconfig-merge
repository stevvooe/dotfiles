#!/usr/bin/env bash
set -euo pipefail

src_dir="${1:-$HOME/.kube/rancher}"
dest="${2:-$HOME/.kube/config}"

mkdir -p "$src_dir"

shopt -s nullglob
files=("$src_dir"/*.yaml "$src_dir"/*.yml)
shopt -u nullglob

if (( ${#files[@]} == 0 )); then
  printf 'no Rancher kubeconfig files found in %s\n' "$src_dir" >&2
  printf 'put downloaded Rancher kubeconfig files there as *.yaml or *.yml, then re-run %s\n' "${0##*/}" >&2
  exit 1
fi

mkdir -p "$(dirname "$dest")"
tmp="$(mktemp "${TMPDIR:-/tmp}/rancher-kubeconfig.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

KUBECONFIG="$(IFS=:; printf '%s' "${files[*]}")" \
  kubectl config view --flatten > "$tmp"

chmod 600 "$tmp"
mv "$tmp" "$dest"

printf 'wrote %s from %d Rancher kubeconfig file(s)\n' "$dest" "${#files[@]}"
kubectl --kubeconfig="$dest" config get-contexts
