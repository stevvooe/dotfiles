#!/usr/bin/env bash

set -euo pipefail

ctp_reset=$'\033[0m'
ctp_mauve=$'\033[38;5;183m'
ctp_lavender=$'\033[38;5;147m'
ctp_green=$'\033[38;5;114m'
ctp_subtext=$'\033[38;5;250m'
fzf_colors='bg:#24273a,bg+:#363a4f,fg:#cad3f5,fg+:#f4dbd6,gutter:#24273a,hl:#f5a97f,hl+:#f5a97f,pointer:#c6a0f6,marker:#a6da95,prompt:#8aadf4,spinner:#8bd5ca,info:#91d7e3,border:#494d64,separator:#363a4f,header:#a5adcb'

if ! command -v fzf >/dev/null 2>&1; then
  printf 'error: fzf not found in PATH\n' >&2
  exit 1
fi

current_session=$(tmux display-message -p '#S')

selection=$(
  tmux list-sessions -F '#{session_name}	#{session_windows}	#{?session_attached,attached,detached}	#{session_activity}' |
    while IFS=$'\t' read -r session windows state activity; do
      if [ "$session" = "$current_session" ]; then
        order=0
        marker="${ctp_mauve}>${ctp_reset}"
        session_label="${ctp_lavender}$(printf '%-28.28s' "$session")${ctp_reset}"
      else
        order=1
        marker=' '
        session_label=$(printf '%-28.28s' "$session")
      fi
      if [ "$state" = "attached" ]; then
        state_label="${ctp_green}$(printf '%-8.8s' "$state")${ctp_reset}"
      else
        state_label="${ctp_subtext}$(printf '%-8.8s' "$state")${ctp_reset}"
      fi
      windows_label="${ctp_subtext}$(printf '%2s windows' "$windows")${ctp_reset}"
      printf '%s\t%s\t%s\t%s %s  %s  %s\n' "$order" "$activity" "$session" "$marker" "$session_label" "$windows_label" "$state_label"
    done |
    sort -t $'\t' -k1,1n -k2,2rn -k3,3 |
    cut -f3- |
    fzf --ansi --color="$fzf_colors" --prompt='session> ' --header='enter switch  esc cancel' --height=100% --layout=reverse --border=rounded --delimiter=$'\t' --with-nth=2
)

if [ -z "$selection" ]; then
  exit 0
fi

session=${selection%%$'\t'*}
tmux switch-client -t "$session"
