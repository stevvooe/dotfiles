{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "instructions": [
    "CLAUDE.md"
  ],
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": {}
    },
    "github": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token) exec github-mcp-server --read-only --toolsets repos,issues,pull_requests,actions stdio"
      ]
    },
    "memorix": {
      "type": "local",
      "command": [
        "memorix",
        "serve"
      ]
    }
  },
  "provider": {
    "local-mlx": {
      "name": "Local MLX",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "lmstudio-community/Qwen3-Coder-30B-A3B-Instruct-MLX-8bit": {
          "name": "Qwen3 Local"
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "github_search_*": "allow",
    "github_list_*": "allow",
    "github_get_*": "allow",
    "github_pull_request_read": "allow",
    "github_issue_read": "allow",
    "github_actions_*": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "webfetch": "allow",
    "memorix_*": "allow",
    "create_entities": "allow",
    "create_relations": "allow",
    "add_observations": "allow",
    "delete_entities": "allow",
    "delete_observations": "allow",
    "delete_relations": "allow",
    "search_nodes": "allow",
    "open_nodes": "allow",
    "read_graph": "allow",
    "skill": {
      "*": "ask",
      "opencode-config": "allow",
      "dotfiles-stow": "allow",
      "brewfile-maintenance": "allow",
      "shell-config": "allow",
      "nvim-config": "allow",
      "memorix-proactive": "allow",
      "stephen-context": "allow",
      "distributed-systems": "allow",
      "cloud-instance-shapes": "allow",
      "github-actions-ci-debug": "allow",
      "design-doc-workflow": "allow",
      "github-pr": "allow"
    },
    "external_directory": {
      "~/code/**": "allow",
      "~/go/**": "allow",
      "~/.cargo/**": "allow",
      "~/.rustup/**": "allow",
      "/tmp/opencode-sandbox/**": "allow",
      "/private/tmp/opencode-sandbox/**": "allow",
      "/var/folders/**/T/opencode-sandbox/**": "allow",
      "/private/var/folders/**/T/opencode-sandbox/**": "allow",
      "/tmp/claude-sandbox/**": "allow",
      "/private/tmp/claude-sandbox/**": "allow"
    },
    "bash": {
      "git *": "ask",
      "git commit*": "deny",
      "git push*": "deny",
      "git rebase*": "deny",
      "git reset*": "deny",
      "git checkout*": "deny",
      "git switch*": "deny",
      "git merge*": "deny",
      "git cherry-pick*": "deny",
      "git revert*": "deny",
      "git stash*": "deny",
      "git tag*": "deny",
      "git branch -d*": "deny",
      "git branch -D*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git ls-files*": "allow",
      "git rev-parse*": "allow",
      "git merge-base*": "allow",
      "git symbolic-ref*": "allow",
      "git branch --show-current*": "allow",
      "git for-each-ref*": "allow",
      "git remote -v*": "allow",
      "git remote get-url*": "allow",
      "git describe*": "allow",
      "git reflog*": "allow",
      "git cat-file*": "allow",
      "gh pr create*": "ask",
      "gh pr edit*": "ask",
      "gh pr merge*": "ask",
      "gh pr close*": "ask",
      "gh pr reopen*": "ask",
      "gh pr ready*": "ask",
      "gh pr review*": "ask",
      "gh issue create*": "ask",
      "gh issue edit*": "ask",
      "gh issue close*": "ask",
      "gh release create*": "ask",
      "gh release edit*": "ask",
      "go test *": "allow",
      "go vet *": "allow",
      "go build *": "allow",
      "gofmt *": "allow",
      "golangci-lint *": "allow",
      "cargo test *": "allow",
      "cargo check *": "allow",
      "cargo build *": "allow",
      "cargo clippy *": "allow",
      "cargo fmt --check*": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "mkdir /tmp/opencode-sandbox*": "allow",
      "mkdir /tmp/claude-sandbox*": "allow"
    }
  }
}
